  "homepage": "https://www.opzyai.com",
  "repository": { "type": "git", "url": "git+https://github.com/thfothijn/opzyai-mcp.git", "directory": "packages/mcp-local" },
  "bugs": { "url": "https://github.com/thfothijn/opzyai-mcp/issues" },
  "bin": { "opzyai-mcp": "dist/cli.js" },
  "files": ["dist", "README.md", "LICENSE"],
  "engines": { "node": ">=20" },
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "tsup",
